#!/bin/bash
#
# git-account - Manage multiple Git accounts easily
#
# A CLI helper to switch between multiple Git identities
# (user.name / user.email) and SSH configurations.

set -euo pipefail

VERSION="0.1.0"

# SSH directory and config file locations (resolved against $HOME).
SSH_DIR="${HOME}/.ssh"
SSH_CONFIG="${SSH_DIR}/config"

# Git identity storage (resolved against $HOME).
GIT_ACCOUNT_DIR="${HOME}/.git-account"
ACCOUNTS_FILE="${GIT_ACCOUNT_DIR}/accounts.txt"
GITCONFIG_FILE="${HOME}/.gitconfig"

# Print usage information.
show_help() {
    cat <<'EOF'
git-account - Manage multiple Git accounts easily

Usage:
    git-account <command> [options]

Commands:
    help, --help, -h        Show this help message
    version, --version, -v  Show the version information
    add                     Add a new account and generate its SSH key
    add-work                Add a work account using an SSH Host alias
    list                    List all configured accounts
    current                 Show the account matching the current directory
    show-key                Print an account's SSH public key
    switch                  Switch an account to a new project path
    remove                  Remove an account and its Git/identity config

Add a new account:
    git-account add <name> <email> <project_path> <domain> [--port <N>]

    Generates ~/.ssh/id_ed25519_<name> and adds a Host entry to
    ~/.ssh/config where Host = <domain>.

    For known platforms (github.com, gitlab.com) the Host entry defaults
    to SSH-over-443 (e.g. HostName ssh.github.com + Port 443) so it works
    behind firewalls that block port 22. Pass --port 22 to use standard
    SSH instead. Unknown platforms default to standard SSH (port 22).

    Examples:
        git-account add personal personal@gmail.com \
            /home/corazon/projects/private/personal github.com
        git-account add personal personal@gmail.com \
            /home/corazon/projects/private/personal github.com --port 22

Add a work account (same platform, multiple accounts):
    git-account add-work <name> <email> <project_path> <domain> [--port <N>]

    Generates ~/.ssh/id_ed25519_<name> and adds a Host alias entry to
    ~/.ssh/config where Host = <name> (e.g. github-work) and
    HostName = the resolved endpoint. Use this alias in remote URLs:
        git@github-work:org/repo.git

    Example:
        git-account add-work github-work work@company.com \
            /home/corazon/projects/private/work github.com

List all accounts:
    git-account list

    Reads ~/.git-account/accounts.txt and prints a table of every
    configured account. Prints a notice when no accounts exist.

Show the account for the current directory:
    git-account current

    Matches the current working directory against the project_path of
    each account, prints the matching account details, and shows the
    effective Git identity (git config user.name / user.email).

Show an account's SSH public key:
    git-account show-key <name>

    Prints the contents of ~/.ssh/id_ed25519_<name>.pub so it can be
    copied straight to GitHub/GitLab SSH Keys. The account must already
    be configured.

    Example:
        git-account show-key personal

Switch an account to a new project path:
    git-account switch <name> <target_path>

    Removes any existing includeIf entry for <target_path> from
    ~/.gitconfig, adds a new includeIf entry pointing at the account's
    identity file, and updates its project_path in accounts.txt. The
    SSH key and ~/.ssh/config entry are left untouched.

    Example:
        git-account switch personal /home/corazon/projects/private/new-path

Remove an account:
    git-account remove <name>

    Deletes ~/.git-account/<name>.gitconfig, removes the matching
    includeIf entry from ~/.gitconfig, and deletes the account line
    from accounts.txt. SSH keys and ~/.ssh/config entries are NOT
    removed, to avoid breaking other accounts that may reference them.

    Example:
        git-account remove personal

Description:
    git-account helps you manage multiple Git identities
    (user.name and user.email) across different repositories
    and SSH configurations. SSH keys use the ed25519 algorithm.

    For each account it also creates ~/.git-account/<name>.gitconfig
    (holding user.name/user.email), adds an [includeIf "gitdir:<path>/"]
    entry to ~/.gitconfig so the right identity is used per project
    directory, and records the account in ~/.git-account/accounts.txt.
EOF
}

# Print the current version.
show_version() {
    echo "git-account version ${VERSION}"
}

# Print an error message to stderr and exit with code 2.
die() {
    echo "error: $*" >&2
    exit 2
}

# Generate an ed25519 SSH key for the given account.
# Usage: generate_ssh_key <name> <email>
generate_ssh_key() {
    local name="$1"
    local email="$2"
    local key_path="${SSH_DIR}/id_ed25519_${name}"

    if [[ -f "${key_path}" ]]; then
        echo "SSH key already exists at ${key_path}, skipping key generation."
        return 0
    fi

    mkdir -p "${SSH_DIR}"
    chmod 700 "${SSH_DIR}"

    ssh-keygen -t ed25519 -C "${email}" -f "${key_path}" -N "" -q
    echo "Generated SSH key: ${key_path}"
}

# Resolve the recommended HostName and Port for a given Git platform domain.
#
# Known platforms that support SSH-over-HTTPS (port 443) return their 443
# endpoint by default, so the generated config works even behind firewalls
# that block the standard SSH port 22.
#
#   github.com  -> ssh.github.com:443
#   gitlab.com  -> alt.gitlab.com:443
#   <other>     -> <domain>:22
#
# An explicit port_override adjusts both values:
#   - port 22  -> fall back to the bare domain, omit Port (standard SSH)
#   - other    -> keep the platform's 443 host (if any) and use the given port
#
# Usage: resolve_ssh_host_settings <domain> [port_override]
# Prints: "<host_name> <port>"
resolve_ssh_host_settings() {
    local domain="$1"
    local port_override="${2:-}"

    local host_name default_port
    case "${domain}" in
        github.com|ssh.github.com)
            host_name="ssh.github.com"
            default_port=443
            ;;
        gitlab.com|alt.gitlab.com)
            host_name="alt.gitlab.com"
            default_port=443
            ;;
        *)
            host_name="${domain}"
            default_port=22
            ;;
    esac

    local port="${port_override:-${default_port}}"

    # Standard SSH (port 22) uses the bare domain; the Port directive is
    # omitted by the caller since 22 is the SSH default.
    if [[ "${port}" == "22" ]]; then
        host_name="${domain}"
    fi

    printf '%s %s' "${host_name}" "${port}"
}

# Append a Host entry to ~/.ssh/config. Skip if the alias already exists.
# The Port directive is only written when the port differs from the SSH
# default (22), keeping the config clean.
# Usage: add_ssh_config_entry <host_alias> <host_name> <name> <email> [port]
add_ssh_config_entry() {
    local host_alias="$1"
    local host_name="$2"
    local name="$3"
    local email="$4"
    local port="${5:-22}"

    mkdir -p "${SSH_DIR}"
    touch "${SSH_CONFIG}"

    if grep -q "^Host ${host_alias}\$" "${SSH_CONFIG}" 2>/dev/null; then
        echo "SSH config entry for Host '${host_alias}' already exists, skipping."
        return 0
    fi

    {
        echo ""
        echo "# ${name} (${email})"
        echo "Host ${host_alias}"
        echo "    HostName ${host_name}"
        echo "    User git"
        if [[ "${port}" != "22" ]]; then
            echo "    Port ${port}"
        fi
        echo "    IdentityFile ~/.ssh/id_ed25519_${name}"
        echo "    IdentitiesOnly yes"
    } >> "${SSH_CONFIG}"

    echo "Added SSH config entry: Host ${host_alias} (${host_name}:${port})"
}

# Normalize a project path into an absolute path with a trailing slash,
# suitable for use in [includeIf "gitdir:<path>/"].
# Usage: normalize_gitdir_path <project_path>
normalize_gitdir_path() {
    local p="$1"
    # Resolve to an absolute path (allow non-existent paths with -m).
    p="$(realpath -m "${p}")"
    # Ensure exactly one trailing slash.
    p="${p%/}/"
    printf '%s' "${p}"
}

# Create ~/.git-account/<name>.gitconfig with user.name and user.email.
# Overwrites any existing file so the identity stays in sync on re-add.
# Usage: create_git_identity <name> <email>
create_git_identity() {
    local name="$1"
    local email="$2"
    local identity_file="${GIT_ACCOUNT_DIR}/${name}.gitconfig"

    mkdir -p "${GIT_ACCOUNT_DIR}"

    cat > "${identity_file}" <<EOF
[user]
    name = ${name}
    email = ${email}
EOF

    echo "Created Git identity: ${identity_file}"
}

# Add an [includeIf "gitdir:<project_path>/"] entry to ~/.gitconfig that
# pulls in the per-account identity file. Skips if an entry for the same
# project path already exists. The gitdir path is always absolute.
# Usage: add_includeif <project_path> <name>
add_includeif() {
    local project_path="$1"
    local name="$2"
    local gitdir_path
    gitdir_path="$(normalize_gitdir_path "${project_path}")"
    local identity_file="${GIT_ACCOUNT_DIR}/${name}.gitconfig"

    touch "${GITCONFIG_FILE}"

    if grep -q "\[includeIf \"gitdir:${gitdir_path}\"\]" "${GITCONFIG_FILE}" 2>/dev/null; then
        echo "includeIf entry for '${gitdir_path}' already exists, skipping."
        return 0
    fi

    {
        echo ""
        echo "[includeIf \"gitdir:${gitdir_path}\"]"
        echo "    path = ${identity_file}"
    } >> "${GITCONFIG_FILE}"

    echo "Added includeIf: gitdir:${gitdir_path}"
}

# Append a record to ~/.git-account/accounts.txt.
# Format: name|email|project_path|domain|key_path
# Skips if an account with the same name already exists.
# Usage: append_account_metadata <name> <email> <project_path> <domain> <key_path>
append_account_metadata() {
    local name="$1"
    local email="$2"
    local project_path="$3"
    local domain="$4"
    local key_path="$5"

    mkdir -p "${GIT_ACCOUNT_DIR}"
    touch "${ACCOUNTS_FILE}"

    if grep -q "^${name}|" "${ACCOUNTS_FILE}" 2>/dev/null; then
        echo "Account '${name}' already in ${ACCOUNTS_FILE}, skipping metadata append."
        return 0
    fi

    printf '%s|%s|%s|%s|%s\n' \
        "${name}" "${email}" "${project_path}" "${domain}" "${key_path}" \
        >> "${ACCOUNTS_FILE}"

    echo "Recorded account metadata in ${ACCOUNTS_FILE}"
}

# Add a new account.
# When is_work=0 the Host is the domain itself; when is_work=1 the Host
# is an alias equal to <name> so multiple accounts on the same platform
# can coexist.
# Usage: add_account <is_work> <name> <email> <project_path> <domain> [port_override]
add_account() {
    local is_work="$1"
    local name="$2"
    local email="$3"
    local project_path="$4"
    local domain="$5"
    local port_override="${6:-}"

    local host_alias
    if [[ "${is_work}" == "1" ]]; then
        host_alias="${name}"
    else
        host_alias="${domain}"
    fi

    local key_path="${SSH_DIR}/id_ed25519_${name}"

    # Resolve the optimal HostName/Port for this domain. Known platforms
    # (github.com, gitlab.com) default to SSH-over-443 to bypass port-22
    # firewalls; --port overrides this.
    local ssh_host_name ssh_port
    read -r ssh_host_name ssh_port <<< "$(resolve_ssh_host_settings "${domain}" "${port_override}")"

    generate_ssh_key "${name}" "${email}"
    add_ssh_config_entry "${host_alias}" "${ssh_host_name}" "${name}" "${email}" "${ssh_port}"
    create_git_identity "${name}" "${email}"
    add_includeif "${project_path}" "${name}"
    append_account_metadata "${name}" "${email}" "${project_path}" "${domain}" "${key_path}"

    echo "Account '${name}' added successfully."
    echo "  Email:        ${email}"
    echo "  Project path: ${project_path}"
    echo "  Domain:       ${domain}"
    echo "  SSH endpoint: ${ssh_host_name}:${ssh_port}"
    echo "  SSH key:      ${key_path}"
    echo "  Host alias:   ${host_alias}"
}

# List all configured accounts as a table.
# Reads ~/.git-account/accounts.txt (format: name|email|project_path|domain|key_path).
# Prints a notice when there are no accounts.
list_accounts() {
    if [[ ! -f "${ACCOUNTS_FILE}" ]] || [[ ! -s "${ACCOUNTS_FILE}" ]]; then
        echo "暂无已配置的账号"
        return 0
    fi

    printf '%-14s %-28s %-46s %-16s %s\n' \
        "NAME" "EMAIL" "PROJECT_PATH" "DOMAIN" "KEY_PATH"
    printf '%.0s-' {1..120}; echo

    local name email project_path domain key_path
    while IFS='|' read -r name email project_path domain key_path; do
        [[ -z "${name}" ]] && continue
        printf '%-14s %-28s %-46s %-16s %s\n' \
            "${name}" "${email}" "${project_path}" "${domain}" "${key_path}"
    done < "${ACCOUNTS_FILE}"
}

# Show the account matching the current working directory.
# Matches when $PWD equals or is nested under an account's project_path.
# Also resolves and displays the effective Git identity via
# `git config user.name` / `git config user.email`.
show_current() {
    local abs_current
    abs_current="$(realpath -m "$(pwd)")"
    abs_current="${abs_current%/}"

    if [[ ! -f "${ACCOUNTS_FILE}" ]] || [[ ! -s "${ACCOUNTS_FILE}" ]]; then
        echo "暂无已配置的账号"
        return 1
    fi

    local name email project_path domain key_path
    while IFS='|' read -r name email project_path domain key_path; do
        [[ -z "${name}" ]] && continue

        local abs_project
        abs_project="$(realpath -m "${project_path}")"
        abs_project="${abs_project%/}"

        if [[ "${abs_current}" == "${abs_project}" || "${abs_current}" == "${abs_project}"/* ]]; then
            echo "当前目录匹配账号: ${name}"
            echo "  邮箱:     ${email}"
            echo "  域名:     ${domain}"
            echo "  密钥路径: ${key_path}"
            echo "  项目路径: ${project_path}"

            local git_name git_email
            if git_name="$(git config user.name 2>/dev/null)"; then
                git_email="$(git config user.email 2>/dev/null)" || git_email=""
                echo "当前 Git 身份: ${git_name} <${git_email}>"
            else
                echo "当前 Git 身份: (未配置或不在 Git 仓库中)"
            fi
            return 0
        fi
    done < "${ACCOUNTS_FILE}"

    echo "当前目录未匹配到任何账号配置: ${abs_current}"
    return 1
}

# Expand a leading ~ to $HOME so key paths stored with a tilde resolve
# correctly regardless of how they were written.
# Usage: expand_tilde <path>
expand_tilde() {
    local p="$1"
    if [[ "${p}" == "~"* ]]; then
        p="${HOME}${p:1}"
    fi
    printf '%s' "${p}"
}

# Show the SSH public key for a configured account.
# Looks up the account's key_path in accounts.txt, appends ".pub", and
# prints the public key contents so it can be copied straight to
# GitHub/GitLab. Errors out when the account or the .pub file is missing.
# Usage: show_key <name>
show_key() {
    local name="$1"

    if [[ ! -f "${ACCOUNTS_FILE}" ]]; then
        echo "❌ 错误: 未找到账号 '${name}'" >&2
        return 1
    fi

    local key_path
    key_path="$(awk -F'|' -v n="${name}" '$1 == n { print $5; exit }' "${ACCOUNTS_FILE}")"

    if [[ -z "${key_path}" ]]; then
        echo "❌ 错误: 未找到账号 '${name}'" >&2
        return 1
    fi

    key_path="$(expand_tilde "${key_path}")"
    local pub_key_path="${key_path}.pub"

    if [[ ! -f "${pub_key_path}" ]]; then
        echo "❌ 错误: 公钥文件不存在: ${pub_key_path}" >&2
        return 1
    fi

    cat "${pub_key_path}"
    echo "# 请将此公钥添加到 GitHub/GitLab SSH Keys 中" >&2
}

# Remove the [includeIf "gitdir:<target_path>/"] entry (and its `path =`
# line) from ~/.gitconfig. Uses a normalized absolute path so any path
# form (trailing slash, relative) is matched. Safe to call when no
# matching entry exists.
# Usage: remove_includeif <target_path>
remove_includeif() {
    local target_path="$1"
    local gitdir_path
    gitdir_path="$(normalize_gitdir_path "${target_path}")"

    touch "${GITCONFIG_FILE}"

    if ! grep -q "\[includeIf \"gitdir:${gitdir_path}\"\]" "${GITCONFIG_FILE}" 2>/dev/null; then
        return 0
    fi

    local tmp_file
    tmp_file="$(mktemp)"
    # Keep everything except the matched includeIf header line and the
    # immediately following "    path = ..." line.
    local skip_next=0
    local line
    local header_re="^\[includeIf \"gitdir:${gitdir_path}\"\]$"
    while IFS= read -r line; do
        if [[ "${line}" =~ ${header_re} ]]; then
            skip_next=1
            continue
        fi
        if [[ "${skip_next}" == "1" ]]; then
            # Drop the path = line (allow leading whitespace).
            if [[ "${line}" == *"path ="* ]]; then
                skip_next=0
                continue
            fi
            skip_next=0
        fi
        printf '%s\n' "${line}"
    done < "${GITCONFIG_FILE}" > "${tmp_file}"

    mv "${tmp_file}" "${GITCONFIG_FILE}"
    echo "Removed includeIf: gitdir:${gitdir_path}"
}

# Remove a line from ~/.git-account/accounts.txt that starts with
# "<name>|". Safe to call when the account is not present.
# Usage: remove_account_metadata_line <name>
remove_account_metadata_line() {
    local name="$1"

    [[ -f "${ACCOUNTS_FILE}" ]] || return 0

    local tmp_file
    tmp_file="$(mktemp)"
    # Keep every line except the one whose first |-field equals <name>.
    awk -F'|' -v n="${name}" '$1 != n' "${ACCOUNTS_FILE}" > "${tmp_file}"
    mv "${tmp_file}" "${ACCOUNTS_FILE}"
}

# Replace the project_path (4th |-field) of an account's line in
# accounts.txt. If the account does not exist, does nothing and returns 1.
# Usage: update_account_project_path <name> <new_project_path>
update_account_project_path() {
    local name="$1"
    local new_project_path="$2"

    [[ -f "${ACCOUNTS_FILE}" ]] || return 1
    grep -q "^${name}|" "${ACCOUNTS_FILE}" || return 1

    local tmp_file
    tmp_file="$(mktemp)"
    awk -F'|' -v OFS='|' -v n="${name}" -v p="${new_project_path}" '
        $1 == n { $3 = p }
        { print }
    ' "${ACCOUNTS_FILE}" > "${tmp_file}"
    mv "${tmp_file}" "${ACCOUNTS_FILE}"
}

# Switch an existing account to a new project path.
# Removes any existing includeIf for the target path, adds a fresh one
# pointing at the account's identity file, and updates accounts.txt.
# The SSH key and ~/.ssh/config entry are left untouched.
# Usage: switch_account <name> <target_path>
switch_account() {
    local name="$1"
    local target_path="$2"
    local identity_file="${GIT_ACCOUNT_DIR}/${name}.gitconfig"

    if [[ ! -f "${identity_file}" ]]; then
        die "account '${name}' not found (missing ${identity_file})"
    fi

    # Look up the account's current project_path so we can remove its old
    # includeIf mapping. An account should only own one path at a time.
    local old_project_path=""
    if [[ -f "${ACCOUNTS_FILE}" ]]; then
        old_project_path="$(awk -F'|' -v n="${name}" '$1 == n { print $3; exit }' "${ACCOUNTS_FILE}")"
    fi

    # Remove the old includeIf entry for this account (if any).
    if [[ -n "${old_project_path}" ]]; then
        remove_includeif "${old_project_path}"
    fi

    # If the target path already has an includeIf (e.g. owned by another
    # account), remove it first so we don't end up with duplicate mappings.
    remove_includeif "${target_path}"

    # Add a fresh includeIf entry for the new path.
    {
        echo ""
        echo "[includeIf \"gitdir:$(normalize_gitdir_path "${target_path}")\"]"
        echo "    path = ${identity_file}"
    } >> "${GITCONFIG_FILE}"
    echo "Added includeIf: gitdir:$(normalize_gitdir_path "${target_path}")"

    if ! update_account_project_path "${name}" "${target_path}"; then
        die "account '${name}' not found in ${ACCOUNTS_FILE}"
    fi

    echo "Switched account '${name}' to project path: ${target_path}"
}

# Remove an account and its Git identity configuration.
# Deletes ~/.git-account/<name>.gitconfig, removes the matching
# includeIf entry from ~/.gitconfig, and deletes the line from
# accounts.txt. SSH keys and ~/.ssh/config are intentionally NOT touched.
# Usage: remove_account <name>
remove_account() {
    local name="$1"
    local identity_file="${GIT_ACCOUNT_DIR}/${name}.gitconfig"

    # Determine the account's current project_path (for includeIf cleanup)
    # before we delete its metadata. Default to empty when not present.
    local current_project_path=""
    if [[ -f "${ACCOUNTS_FILE}" ]]; then
        current_project_path="$(awk -F'|' -v n="${name}" '$1 == n { print $3; exit }' "${ACCOUNTS_FILE}")"
    fi

    # 1. Remove the per-account identity file.
    if [[ -f "${identity_file}" ]]; then
        rm -f "${identity_file}"
        echo "Deleted Git identity: ${identity_file}"
    else
        echo "Git identity not found: ${identity_file} (already removed?)"
    fi

    # 2. Remove the includeIf entry pointing at this account's project path.
    if [[ -n "${current_project_path}" ]]; then
        remove_includeif "${current_project_path}"
    fi

    # 3. Remove the account line from accounts.txt.
    local existed
    if [[ -f "${ACCOUNTS_FILE}" ]] && grep -q "^${name}|" "${ACCOUNTS_FILE}"; then
        existed=1
    else
        existed=0
    fi
    remove_account_metadata_line "${name}"
    if [[ "${existed}" == "1" ]]; then
        echo "Removed account '${name}' from ${ACCOUNTS_FILE}"
    else
        echo "Account '${name}' not found in ${ACCOUNTS_FILE} (already removed?)"
    fi

    echo "Account '${name}' removed (SSH key and ~/.ssh/config left intact)."
}

# Main entry point.
main() {
    local cmd="${1:-}"

    case "${cmd}" in
        help|--help|-h)
            show_help
            ;;
        version|--version|-v)
            show_version
            ;;
        add|add-work)
            local sub_cmd="${cmd}"
            shift
            local port_override=""
            local positional=()
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --port)
                        [[ $# -ge 2 ]] || die "--port requires a value"
                        port_override="$2"
                        shift 2
                        ;;
                    --port=*)
                        port_override="${1#--port=}"
                        shift
                        ;;
                    --)
                        shift
                        positional+=("$@")
                        break
                        ;;
                    *)
                        positional+=("$1")
                        shift
                        ;;
                esac
            done
            if [[ ${#positional[@]} -ne 4 ]]; then
                die "${sub_cmd} requires 4 arguments: <name> <email> <project_path> <domain>"
            fi
            if [[ "${sub_cmd}" == "add" ]]; then
                add_account 0 "${positional[@]}" "${port_override}"
            else
                add_account 1 "${positional[@]}" "${port_override}"
            fi
            ;;
        list)
            list_accounts
            ;;
        current)
            show_current
            ;;
        show-key|show)
            shift
            if [[ $# -ne 1 ]]; then
                die "show-key requires 1 argument: <name>"
            fi
            show_key "$@"
            ;;
        switch)
            shift
            if [[ $# -ne 2 ]]; then
                die "switch requires 2 arguments: <name> <target_path>"
            fi
            switch_account "$@"
            ;;
        remove)
            shift
            if [[ $# -ne 1 ]]; then
                die "remove requires 1 argument: <name>"
            fi
            remove_account "$@"
            ;;
        "")
            show_help
            ;;
        *)
            echo "Unknown command: ${cmd}" >&2
            echo "Run 'git-account help' for usage information." >&2
            exit 1
            ;;
    esac
}

main "$@"
